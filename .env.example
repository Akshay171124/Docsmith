# Copy to .env for local development. Never commit the real .env.

# Claude Sonnet — used for staleness verification, repair, and validation.
ANTHROPIC_API_KEY=

# GitHub token — used for reading diffs and opening PRs/comments during local runs.
GITHUB_TOKEN=

# Optional: override the local embedding model (defaults to BAAI/bge-small-en-v1.5).
# DOCSMITH_EMBEDDING_MODEL=
